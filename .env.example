# ── Flask ──────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_random_32char_string

# ── MongoDB (use MongoDB Atlas URI for cloud) ──────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/hair_beard_ai?retryWrites=true&w=majority

# ── File uploads ───────────────────────────────────────────────
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=16777216

# ── Production vs development ──────────────────────────────────
DEBUG=False

# ── External APIs ──────────────────────────────────────────────
REPLICATE_API_TOKEN=your_replicate_token_here
GEMINI_API_KEY=your_gemini_api_key_here
